# UnifyOps Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env itself.

# Application
APP_NAME=UnifyOps
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# Server
HOST=0.0.0.0
PORT=8000

# CORS — allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Firebase Admin SDK
# Path to the Firebase service account JSON key file (for backend token verification)
# Download from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# CORS Front-End Allowed Origin
FRONTEND_URL=http://localhost:3000

# ─── GCP Services ───
GCP_PROJECT_ID=
GCP_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=

# Cloud Storage
GCS_BUCKET_NAME=

# Document AI Processor IDs (FR-1.2, FR-1.3, FR-1.4)
DOCAI_OCR_PROCESSOR_ID=
DOCAI_CLASSIFIER_PROCESSOR_ID=
DOCAI_PID_EXTRACTOR_PROCESSOR_ID=

# Gemini (Google AI Studio API Key) (FR-1.5, FR-1.6)
GEMINI_API_KEY=

# Classification confidence threshold (FR-1.2.2)
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.80

# Entity extraction confidence threshold (FR-1.5.4)
ENTITY_CONFIDENCE_THRESHOLD=0.85

# Groq (Fallback LLM provider)
GROQ_API_KEY=

