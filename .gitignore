# ==========================
# UnifyOps .gitignore
# ==========================

# ----- Environment & Secrets -----
.env
.env.local
.env.*.local
*.pem
*.key

# Wildcard ignore for database and credentials, but whitelist config JSONs
*.json
!package.json
!package-lock.json
!tsconfig.json
!jsconfig.json
!*.tfvars.example
!*example*.json
!metadata.json

# Explicitly ignore local dev database and service accounts
db.json
*service-account*.json
*service_account*.json
unifyops-*.json


# ----- Python / Backend -----
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
.Python
build/
dist/
*.egg-info/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ----- Node / Frontend -----
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Docker -----
docker-compose.override.yml

# ----- Terraform (for future GCP infra) -----
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
